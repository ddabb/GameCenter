<!-- level-select.wxml - 选关页面（支持难度分级） -->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="onBack">← 返回</view>
    <view class="title">{{displayName}} - 选关</view>
  </view>

  <!-- 难度 Tab（仅支持难度的游戏显示） -->
  <view class="tabs" wx:if="{{showDifficultyTabs}}">
    <view
      wx:for="{{difficulties}}"
      wx:key="key"
      class="tab {{difficulty === item.key ? 'active' : ''}}"
      data-diff="{{item.key}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 关卡网格 -->
  <scroll-view
    class="level-grid"
    scroll-y
    bindscrolltolower="onReachBottom"
  >
    <view class="grid-container">
      <view
        wx:for="{{levels}}"
        wx:key="level"
        class="level-btn {{item.locked ? 'locked' : ''}}"
        data-level="{{item.level}}"
        bindtap="onLevelTap"
      >
        <text class="level-num">{{item.level}}</text>
        <view class="stars" wx:if="{{item.stars > 0}}">
          <text wx:for="{{item.stars}}" wx:key="*this">★</text>
        </view>
        <view class="lock" wx:if="{{item.locked}}">🔒</view>
      </view>
    </view>
  </scroll-view>
</view>
