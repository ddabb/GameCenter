[node name="DescriptionLabel" type="Label" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
text = "数墙游戏是一款源自日本的逻辑推理谜题。\n\n游戏规则：\n• 用黑色方块将数字分隔开\n• 每个数字表示其所在白色区域包含的格子数\n• 黑色区域必须是连续的\n• 不能出现2×2的黑色方块\n• 所有白色区域都必须包含一个数字\n\n运用逻辑推理，找出所有黑白方块的位置！"
